{
  "name": "mimo-platform",
  "version": "0.0.0",
  "license": "AGPL-3.0-only",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "test": "bun test",
    "test.full": "bun test --config /dev/null test/ integration-test/",
    "test:watch": "bun test --watch",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/chokidar": "^2.1.7",
    "@types/js-yaml": "^4.0.9",
    "prettier": "^3.8.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "hono": "^4.12.10",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "jscpd": "^4.0.5",
    "yaml": "^2.8.3"
  }
}
